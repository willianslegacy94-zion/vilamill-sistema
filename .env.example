# ─── Banco de Dados ────────────────────────────────────────────────────────────
# Produção (Docker Compose) → host = "db" (nome do serviço)
DATABASE_URL="postgresql://postgres:postgres@db:5432/villamill"
DIRECT_URL="postgresql://postgres:postgres@db:5432/villamill"

# Dev local (fora do Docker, yarn dev) → troque "db" por "localhost"
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/villamill"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/villamill"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Gere um valor seguro com: openssl rand -base64 32
AUTH_SECRET="dev-secret-mude-em-producao"
NEXTAUTH_URL="https://villamill.online"
