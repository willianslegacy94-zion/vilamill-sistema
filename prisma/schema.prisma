datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Table {
  id     String      @id @default(cuid())
  numero Int         @unique
  status TableStatus @default(LIVRE)
  orders Order[]
}

model Product {
  id              String               @id @default(cuid())
  nome            String
  preco           Decimal              @db.Decimal(10, 2)
  costPrice       Decimal              @db.Decimal(10, 2) @default(0)
  categoria       String
  track_inventory Boolean              @default(false)
  estoque         Decimal              @db.Decimal(10, 3) @default(0)
  opcionais       Json?
  orderItems      OrderItem[]
  recipeItems     RecipeItem[]
  consumosFuncionario ConsumoFuncionario[]
}

model Ingredient {
  id                String         @id @default(cuid())
  nome              String
  unidade           IngredientUnit
  quantidadeAtual   Decimal        @db.Decimal(10, 3)
  nivelMinimoAlerta Decimal        @db.Decimal(10, 3)
  recipeItems       RecipeItem[]
}

model RecipeItem {
  id           String     @id @default(cuid())
  productId    String
  ingredientId String
  quantidade   Decimal    @db.Decimal(10, 3)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
}

model Order {
  id               String          @id @default(cuid())
  mesaId           String
  paymentStatus    PaymentStatus   @default(PENDENTE)
  total            Decimal         @db.Decimal(10, 2)
  desconto         Decimal         @db.Decimal(10, 2) @default(0)
  closedAt         DateTime?
  createdAt        DateTime        @default(now())
  formaPagamento   FormaPagamento?
  pagamentosSplit  Json?
  caixaNome        String?
  table            Table           @relation(fields: [mesaId], references: [id])
  items            OrderItem[]
}

model Caixa {
  id        String   @id @default(cuid())
  nome      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model CancelamentoLog {
  id                 String   @id @default(cuid())
  mesaNumero         Int
  motivoCancelamento String?
  canceladoPor       String
  canceladoEm        DateTime @default(now())
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantidade  Decimal  @db.Decimal(10, 3)
  precoUnit   Decimal  @db.Decimal(10, 2)
  custoUnit   Decimal  @db.Decimal(10, 2) @default(0)
  subtotal    Decimal  @db.Decimal(10, 2)
  observacoes String?
  status      String   @default("PENDENTE")
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  role      UserRole @default(CAIXA)
}

model Despesa {
  id            String   @id @default(cuid())
  descricao     String
  valor         Decimal  @db.Decimal(10, 2)
  categoria     String
  data          DateTime
  registradoPor String
  createdAt     DateTime @default(now())
}

enum TableStatus {
  LIVRE
  OCUPADA
  CONTA
}

enum PaymentStatus {
  PENDENTE
  PAGO
}

enum FormaPagamento {
  DINHEIRO
  CARTAO
  CREDITO
  DEBITO
  PIX
  VOUCHER
}

enum UserRole {
  ADMIN
  CAIXA
  COZINHA
}

enum IngredientUnit {
  KG
  UN
  L
}

enum TipoCreditoFuncionario {
  INDIVIDUAL
  COLETIVO
}

enum TipoLancamento {
  DINHEIRO
  PRODUTO
}

enum StatusLancamento {
  PENDENTE
  PAGO
}

model FuncionarioExterno {
  id          String               @id @default(cuid())
  nome        String
  empresa     String
  setor       String               @default("Lava-Rápido")
  ativo       Boolean              @default(true)
  createdAt   DateTime             @default(now())
  creditos    CreditoFuncionario[]
  consumos    ConsumoFuncionario[]
  lancamentos LancamentoVale[]
}

model LancamentoVale {
  id            String           @id @default(cuid())
  colaboradorId String
  colaborador   FuncionarioExterno @relation(fields: [colaboradorId], references: [id])
  tipo          TipoLancamento
  descricao     String
  valor         Decimal          @db.Decimal(10, 2)
  status        StatusLancamento @default(PENDENTE)
  registradoPor String
  createdAt     DateTime         @default(now())
  liquidadoEm   DateTime?
}

model CreditoFuncionario {
  id            String                  @id @default(cuid())
  funcionarioId String?
  funcionario   FuncionarioExterno?     @relation(fields: [funcionarioId], references: [id])
  empresa       String?
  valor         Decimal                 @db.Decimal(10, 2)
  descricao     String?
  tipo          TipoCreditoFuncionario  @default(INDIVIDUAL)
  loteId        String?
  registradoPor String
  registradoEm  DateTime                @default(now())
  liquidado     Boolean                 @default(false)
  liquidadoEm   DateTime?
}

model ConsumoFuncionario {
  id            String             @id @default(cuid())
  funcionarioId String
  funcionario   FuncionarioExterno @relation(fields: [funcionarioId], references: [id])
  productId     String
  product       Product            @relation(fields: [productId], references: [id])
  quantidade    Decimal            @db.Decimal(10, 3)
  precoUnit     Decimal            @db.Decimal(10, 2)
  subtotal      Decimal            @db.Decimal(10, 2)
  registradoPor String
  registradoEm  DateTime           @default(now())
  liquidado     Boolean            @default(false)
  liquidadoEm   DateTime?
}
